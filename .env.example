# Simulated Social Lamp local configuration. Copy to .env and keep .env private.
#
# Settings are grouped into required defaults and optional overrides.
# Required settings have defaults that work for offline/runtime replay mode.

## Required — copy these defaults as-is
CONVERSATION_PROVIDER=template
ENABLE_CLOUD_CONVERSATION=false
DATABASE_PATH=.runtime/memory.db
ENABLE_LIVE_CAPTURE=false
ENABLE_AUDIO_BONUS=false

## Optional — uncomment and configure as needed
# OPENAI_API_KEY=sk-...
# SNAPSHOT_PATH=.runtime/snapshots
# CAMERA_INDEX=0
# RETENTION_DAYS=7
# OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview

## Face detection
# Mode: auto | mediapipe | opencv | heuristic | disabled
# auto tries MediaPipe first, falls back to OpenCV, then heuristic
FACE_DETECTOR_MODE=auto
# Legacy alias — setting this to true forces FACE_DETECTOR_MODE=mediapipe
# when FACE_DETECTOR_MODE is auto (default)
ENABLE_MEDIAPIPE_FACE_LANDMARKER=false

## Object detection (YOLO) — also optional
# Model weights are intentionally untracked (see .gitignore for *.pt). Download
# with: curl -L -o models/yolov8n.pt https://github.com/ultralytics/assets/releases/download/v8.2.0/yolov8n.pt
# or just set OBJECT_DETECTOR_MODEL=yolov8n.pt and ultralytics will auto-download.
ENABLE_OBJECT_DETECTION=false
OBJECT_DETECTOR_MODEL=yolov8n.pt
OBJECT_DETECTION_CONFIDENCE=0.45
OBJECT_DETECTION_MAX_FPS=8
# OBJECT_DETECTION_CLASSES=0,1,2  # Optional COCO class ID allowlist (comma-separated)
