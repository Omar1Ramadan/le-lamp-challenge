# Simulated Social Lamp local configuration. Copy to .env and keep .env private.
CONVERSATION_PROVIDER=template
ENABLE_CLOUD_CONVERSATION=false
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview
# OPENAI_API_KEY=sk-...
DATABASE_PATH=.runtime/memory.db
SNAPSHOT_PATH=.runtime/snapshots
CAMERA_INDEX=0
ENABLE_LIVE_CAPTURE=false
RETENTION_DAYS=7
ENABLE_AUDIO_BONUS=false
# Face detector mode: auto | mediapipe | opencv | heuristic | disabled
# auto tries MediaPipe first, falls back to OpenCV, then heuristic
FACE_DETECTOR_MODE=auto
# Legacy alias — setting this to true forces FACE_DETECTOR_MODE=mediapipe
# when FACE_DETECTOR_MODE is auto (default)
ENABLE_MEDIAPIPE_FACE_LANDMARKER=false
